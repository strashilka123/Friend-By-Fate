  m_Script: {fileID: 11500000, guid: 355d2ebe39fc7284e8ce889682a20b9a, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  _stories:
  - <Tag>k__BackingField: Smth1
    <Text>k__BackingField: "\u041A\u0432\u0430\u0440\u0442\u0438\u0440\u0430 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0430..."
    <Answers>k__BackingField:
    - <Text>k__BackingField: "\u0414\u0430\u043B\u0435\u0435"
      <ReposeText>k__BackingField: NPC1.1
    <VoiceClip>k__BackingField: {fileID: 0}
  - <Tag>k__BackingField: NPC1.1
    <Text>k__BackingField: "\u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440:
      \u0420\u0430\u043D\u044C\u0448\u0435 \u044F \u0442\u0430\u043A\u0438\u0435
      \u0432\u0435\u0447\u0435\u0440\u0430 \u043D\u0435\u043D\u0430\u0432\u0438\u0434\u0435\u043B.
      \u0422\u0438\u0448\u0438\u043D\u0430 \u0437\u0434\u0435\u0441\u044C\u2026 \u0434\u0430\u0432\u0438\u043B\u0430.
      \\n\u041A\u0430\u043A \u0431\u0443\u0434\u0442\u043E \u043A\u0432\u0430\u0440\u0442\u0438\u0440\u0430
      \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0441\u044F \u043C\u0435\u043D\u044C\u0448\u0435."
    <Answers>k__BackingField:
    - <Text>k__BackingField: "\u0414\u0430\u043B\u0435\u0435"
      <ReposeText>k__BackingField: Player1
    <VoiceClip>k__BackingField: {fileID: 0}
  - <Tag>k__BackingField: Player1
    <Text>k__BackingField: "\u0412\u044B: \u0410 \u0441\u0435\u0439\u0447\u0430\u0441
      \u0447\u0442\u043E?"
    <Answers>k__BackingField:
    - <Text>k__BackingField: "\u0414\u0430\u043B\u0435\u0435"
      <ReposeText>k__BackingField: NPC2
    <VoiceClip>k__BackingField: {fileID: 0}
  - <Tag>k__BackingField: NPC2
    <Text>k__BackingField: "\u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440:
      \u0421\u0435\u0439\u0447\u0430\u0441\u2026 \u043D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E.
      \u0414\u0430\u0436\u0435 \u0441\u043F\u043E\u043A\u043E\u0439\u043D\u043E.
      \u041D\u0430\u0432\u0435\u0440\u043D\u043E\u0435 \u043F\u043E\u0442\u043E\u043C\u0443
      \u0447\u0442\u043E \u0442\u044B \u0437\u0434\u0435\u0441\u044C."
    <Answers>k__BackingField:
    - <Text>k__BackingField: "\u0414\u0430\u043B\u0435\u0435"
      <ReposeText>k__BackingField: cards
    <VoiceClip>k__BackingField: {fileID: 0}
  - <Tag>k__BackingField: cards
    <Text>k__BackingField: "\u0421\u0446\u0435\u043D\u0430: \u041E\u043D\u0438 \u0438\u0433\u0440\u0430\u044E\u0442
      \u0432 \u043A\u0430\u0440\u0442\u044B. "
    <Answers>k__BackingField:
    - <Text>k__BackingField: "\u0414\u0430\u043B\u0435\u0435"
      <ReposeText>k__BackingField: NPC2
    <VoiceClip>k__BackingField: {fileID: 0}
