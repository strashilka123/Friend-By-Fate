--- !u!114 &2081428519
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2081428515}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 355d2ebe39fc7284e8ce889682a20b9a, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  _stories:
  - <Tag>k__BackingField: NPC1
    <Text>k__BackingField: "\u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440
      (\u0441\u043C\u043E\u0442\u0440\u0438\u0442 \u043D\u0430 \u0440\u0443\u043A\u0438):
      \u0422\u044B \u0432\u0435\u0434\u044C \u043C\u043E\u0433 \u043F\u0440\u043E\u0441\u0442\u043E
      \u0443\u0439\u0442\u0438... \u041F\u043E\u0447\u0435\u043C\u0443 \u0442\u044B
      \u043E\u0441\u0442\u0430\u043B\u0441\u044F!?!"
    <Answers>k__BackingField:
    - <Text>k__BackingField: "\u0422\u044B \u043D\u0435 \u0437\u0430\u0441\u043B\u0443\u0436\u0438\u0432\u0430\u0435\u0448\u044C
        \u0442\u0430\u043A\u043E\u0433\u043E \u043E\u0431\u0440\u0430\u0449\u0435\u043D\u0438\u044F
        \u043A \u0441\u0435\u0431\u0435!"
      <ReposeText>k__BackingField: NPC1.2
    - <Text>k__BackingField: "\u0422\u0440\u043E\u0435 \u043D\u0430 \u043E\u0434\u043D\u043E\u0433\u043E!
        \\n\u0422\u044B \u0431\u044B \u043D\u0435 \u0432\u044B\u0432\u0435\u0437!"
      <ReposeText>k__BackingField: NPC1.2
    - <Text>k__BackingField: "\u041F\u0440\u043E\u0441\u0442\u043E \u0445\u043E\u0442\u0435\u043B\u043E\u0441\u044C
        \\n\u043A\u043E\u043C\u0443-\u043D\u0438\u0431\u0443\u0434\u044C \u0432\u0440\u0435\u0437\u0430\u0442\u044C!"
      <ReposeText>k__BackingField: Smth4
    <VoiceClip>k__BackingField: {fileID: 0}
  - <Tag>k__BackingField: NPC1.2
    <Text>k__BackingField: "\u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440:
      \u0417\u0430 \u043C\u0435\u043D\u044F \u043E\u0431\u044B\u0447\u043D\u043E
      \u043D\u0435 \u0432\u0441\u0442\u0443\u043F\u0430\u044E\u0442\u0441\u044F.
      \\n\u042F \u043B\u0438\u0431\u043E \xAB\u043D\u0435 \u0442\u043E\u0442\xBB,
      \u043B\u0438\u0431\u043E \xAB\u043D\u0435 \u0432\u043E\u0432\u0440\u0435\u043C\u044F\xBB...
      \u0441\u043F\u0430\u0441\u0438\u0431\u043E \u0442\u0435\u0431\u0435"
    <Answers>k__BackingField:
    - <Text>k__BackingField: "\u0414\u0430\u043B\u0435\u0435"
      <ReposeText>k__BackingField: Smth4
    <VoiceClip>k__BackingField: {fileID: 0}
  - <Tag>k__BackingField: Smth4
    <Text>k__BackingField: "\u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440:
      \u041B\u0430\u0434\u043D\u043E.. \u0438\u0434\u0451\u043C"
    <Answers>k__BackingField: []
    <VoiceClip>k__BackingField: {fileID: 0}
