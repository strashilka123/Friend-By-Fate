--- !u!114 &1771279024
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1771279022}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 355d2ebe39fc7284e8ce889682a20b9a, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  _stories:
  - <Tag>k__BackingField: Player1
    <Text>k__BackingField: "\u0412\u044B: \u0414\u0435\u043D\u044C \u043D\u0435 \u0437\u0430\u0434\u0430\u043B\u0441\u044F?"
    <Answers>k__BackingField:
    - <Text>k__BackingField: "\u0414\u0430\u043B\u0435\u0435"
      <ReposeText>k__BackingField: NPC1
    <VoiceClip>k__BackingField: {fileID: 0}
  - <Tag>k__BackingField: NPC1
    <Text>k__BackingField: "\u041A\u0442\u043E-\u0442\u043E: \u0420\u0430\u0437\u0432\u0435
      \u0431\u044B\u0432\u0430\u0435\u0442 \u0438\u043D\u0430\u0447\u0435?"
    <Answers>k__BackingField:
    - <Text>k__BackingField: "\u0414\u0430\u043B\u0435\u0435"
      <ReposeText>k__BackingField: Player2
    <VoiceClip>k__BackingField: {fileID: 8300000, guid: 8e549828aa0a04d4397f54f827310752, type: 3}
  - <Tag>k__BackingField: Player2
    <Text>k__BackingField: "\u0412\u044B: \u0418\u043D\u043E\u0433\u0434\u0430. \u041D\u043E
      \u0440\u0435\u0434\u043A\u043E."
    <Answers>k__BackingField:
    - <Text>k__BackingField: "\u0414\u0430\u043B\u0435\u0435"
      <ReposeText>k__BackingField: Think1
    <VoiceClip>k__BackingField: {fileID: 0}
  - <Tag>k__BackingField: Think1
    <Text>k__BackingField: "(\u043E\u043D \u0432\u043F\u0435\u0440\u0432\u044B\u0435
      \u043F\u043E\u0434\u043D\u0438\u043C\u0430\u0435\u0442 \u0432\u0437\u0433\u043B\u044F\u0434)"
    <Answers>k__BackingField:
    - <Text>k__BackingField: "\u0414\u0430\u043B\u0435\u0435"
      <ReposeText>k__BackingField: "\u0432\u044B\u0431\u043E\u0440_1"
    <VoiceClip>k__BackingField: {fileID: 0}
  - <Tag>k__BackingField: "\u0432\u044B\u0431\u043E\u0440_1"
    <Text>k__BackingField: "\u041A\u0442\u043E-\u0442\u043E: \u0417\u043D\u0430\u0447\u0438\u0442...
      \u0442\u0435\u0431\u0435 \u043F\u043E\u0432\u0435\u0437\u043B\u043E \u0447\u0443\u0442\u044C
      \u0431\u043E\u043B\u044C\u0448\u0435, \u0447\u0435\u043C \u043C\u043D\u0435."
    <Answers>k__BackingField:
    - <Text>k__BackingField: "\u0425\u043E\u0447\u0435\u0448\u044C \u043F\u043E\u0433\u043E\u0432\u043E\u0440\u0438\u0442\u044C?"
      <ReposeText>k__BackingField: NPC2.1
    - <Text>k__BackingField: "\u042F \u043C\u043E\u0433\u0443 \u043F\u0440\u043E\u0441\u0442\u043E
        \u043F\u043E\u0441\u0438\u0434\u0435\u0442\u044C \u0440\u044F\u0434\u043E\u043C"
      <ReposeText>k__BackingField: "\u0432\u044B\u0431\u043E\u0440_1"
    - <Text>k__BackingField: "\u0423 \u0432\u0441\u0435\u0445 \u0431\u044B\u0432\u0430\u044E\u0442
        \u0434\u0435\u0440\u044C\u043C\u043E\u0432\u044B\u0435 \u0434\u043D\u0438,
        \u043D\u0435 \u0442\u044B \u043E\u0434\u0438\u043D \u0442\u0430\u043A\u043E\u0439!"
      <ReposeText>k__BackingField: "\u0432\u044B\u0431\u043E\u0440_1"
    <VoiceClip>k__BackingField: {fileID: 8300000, guid: e6ce187ab413de14c962200b50c830a8, type: 3}
  - <Tag>k__BackingField: NPC2.1
    <Text>k__BackingField: "\u041A\u0442\u043E-\u0442\u043E: \u041B\u044E\u0434\u0438
      \u043E\u0431\u044B\u0447\u043D\u043E \u043D\u0435 \u0441\u043F\u0440\u0430\u0448\u0438\u0432\u0430\u044E\u0442.
      \u0418\u043C \u0432\u0441\u0451 \u0440\u0430\u0432\u043D\u043E."
    <Answers>k__BackingField:
    - <Text>k__BackingField: "\u0414\u0430\u043B\u0435\u0435"
      <ReposeText>k__BackingField: Player3.1
    <VoiceClip>k__BackingField: {fileID: 8300000, guid: 6c21db87c404942448403496703a5806, type: 3}
  - <Tag>k__BackingField: Player3.1
    <Text>k__BackingField: "\u0412\u044B: \u0410 \u043C\u043D\u0435 \u2014 \u043D\u0435\u0442!"
    <Answers>k__BackingField:
    - <Text>k__BackingField: "\u0414\u0430\u043B\u0435\u0435"
      <ReposeText>k__BackingField: NPC2.2
    <VoiceClip>k__BackingField: {fileID: 0}
  - <Tag>k__BackingField: NPC2.2
    <Text>k__BackingField: "\u041A\u0442\u043E-\u0442\u043E: \u0421\u0430\u0448\u0430...
      \u0438\u043B\u0438 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440.
      \u041A\u0430\u043A \u0445\u043E\u0447\u0435\u0448\u044C. \u041C\u043D\u0435
      \u0432\u0441\u0451 \u0440\u0430\u0432\u043D\u043E."
    <Answers>k__BackingField:
    - <Text>k__BackingField: "\u0414\u0430\u043B\u0435\u0435"
      <ReposeText>k__BackingField: Player3.2
    <VoiceClip>k__BackingField: {fileID: 8300000, guid: 58422599eb594594e916821479a7c059, type: 3}
  - <Tag>k__BackingField: Player3.2
    <Text>k__BackingField: "\u0412\u044B: \u0422\u043E\u0433\u0434\u0430.. \u0440\u0430\u0434
      \u0437\u043D\u0430\u043A\u043E\u043C\u0441\u0442\u0432\u0443, \u0421\u0430\u0448\u0430!"
    <Answers>k__BackingField:
    - <Text>k__BackingField: "\u0414\u0430\u043B\u0435\u0435"
      <ReposeText>k__BackingField: NPC2.3
    <VoiceClip>k__BackingField: {fileID: 0}
  - <Tag>k__BackingField: NPC2.3
    <Text>k__BackingField: "\u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440:
      \u041D\u0443 \u0432\u0437\u0430\u0438\u043C\u043D\u043E.. \u043D\u0430\u0432\u0435\u0440\u043D\u043E\u0435"
    <Answers>k__BackingField:
    - <Text>k__BackingField: "\u0414\u0430\u043B\u0435\u0435"
      <ReposeText>k__BackingField: Player3.3
    <VoiceClip>k__BackingField: {fileID: 8300000, guid: 36cb8be715393cf4c9554314d16420ec, type: 3}
  - <Tag>k__BackingField: Player3.3
    <Text>k__BackingField: "\u0412\u044B: \u0421 \xAB\u043D\u0430\u0432\u0435\u0440\u043D\u043E\u0435\xBB
      \u0442\u043E\u0436\u0435 \u043C\u043E\u0436\u043D\u043E \u043D\u0430\u0447\u0430\u0442\u044C."
    <Answers>k__BackingField: []
    <VoiceClip>k__BackingField: {fileID: 0}
  - <Tag>k__BackingField: "\u0418\u0433\u0440\u043E\u043A_3.2"
    <Text>k__BackingField: "\u0412\u044B: \u0420\u0430\u0434 \u0437\u043D\u0430\u043A\u043E\u043C\u0441\u0442\u0432\u0443."
    <Answers>k__BackingField: []
    <VoiceClip>k__BackingField: {fileID: 0}
