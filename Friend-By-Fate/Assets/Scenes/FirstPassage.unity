--- !u!114 &1635632209496244727
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 892218562729461051}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 355d2ebe39fc7284e8ce889682a20b9a, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  _stories:
  - <Tag>k__BackingField: NPC1
    <Text>k__BackingField: "\u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440:
      \u0412\u043E\u0442 \u0432\u0438\u0434\u0438\u0448\u044C? \u042F \u043A\u0430\u043A
      \u0431\u0443\u0434\u0442\u043E \u043B\u0438\u0448\u043D\u0438\u0439 \u044D\u043B\u0435\u043C\u0435\u043D\u0442!
      \u0411\u0443\u0434\u0442\u043E \u0441\u0438\u0441\u0442\u0435\u043C\u0430 \u0431\u0435\u0437
      \u0442\u0435\u0431\u044F \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442 \u0434\u0430\u0436\u0435
      \u043B\u0443\u0447\u0448\u0435."
    <Answers>k__BackingField:
    - <Text>k__BackingField: "\u0414\u0430\u043B\u0435\u0435"
      <ReposeText>k__BackingField: Player1
    <VoiceClip>k__BackingField: {fileID: 8300000, guid: 6d58b7f64eb5b524fbd43affb17e76d6, type: 3}
  - <Tag>k__BackingField: Player1
    <Text>k__BackingField: "\u0412\u044B: \u0417\u043D\u0430\u0435\u0448\u044C, \u044F
      \u0441\u0435\u0439\u0447\u0430\u0441 \u0438\u0434\u0443 \u0432 \u0431\u0430\u0440.
      \u041F\u043E\u0439\u0434\u0451\u0448\u044C?"
    <Answers>k__BackingField:
    - <Text>k__BackingField: "\u0414\u0430\u043B\u0435\u0435"
      <ReposeText>k__BackingField: Smth
    <VoiceClip>k__BackingField: {fileID: 0}
  - <Tag>k__BackingField: Smth
    <Text>k__BackingField: "\u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440
      (\u043C\u0435\u0434\u043B\u0435\u043D\u043D\u043E \u043A\u0438\u0432\u0430\u044F
      \u0433\u043E\u043B\u043E\u0432\u043E\u0439): \u041D\u0443.. \u0438\u0434\u0451\u043C"
    <Answers>k__BackingField: []
    <VoiceClip>k__BackingField: {fileID: 8300000, guid: 3d1f0f40ced3287428df37db00c176dc, type: 3}
